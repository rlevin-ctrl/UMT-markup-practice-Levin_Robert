PORT=3000
NODE_ENV=development

# Local PostgreSQL or Render external URL
DATABASE_URL=postgres://user:password@localhost:5432/flora

# Public URL of this backend (for photoURL in responses)
APP_URL=http://localhost:3000

# Optional: comma-separated origins for CORS (defaults to *)
CLIENT_ORIGIN=http://localhost:4000,https://rlevin-ctrl.github.io
